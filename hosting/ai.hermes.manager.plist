<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>ai.hermes.manager</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>scripts/start-prod.sh</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/tumf/services/hermes-manager</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PORT</key>
    <string>18470</string>
    <key>NODE_ENV</key>
    <string>production</string>
  </dict>

  <key>StandardOutPath</key>
  <string>/Users/tumf/services/hermes-manager/runtime/logs/webapp.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/tumf/services/hermes-manager/runtime/logs/webapp.error.log</string>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <true/>
</dict>
</plist>
