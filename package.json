{
  "name": "hermes-agents",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 18470 --hostname 0.0.0.0",
    "build": "next build",
    "start": "next start -p 18470",
    "start:prod": "bash scripts/start-prod.sh",
    "lint": "next lint --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "prepare": "husky"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
